{
  "imports": {
    "@db/postgres": "jsr:@db/postgres@^0.19.5",
    "@auth0/auth0-hono": "npm:@auth0/auth0-hono",
    "@std/assert": "jsr:@std/assert@^1.0.16",
    "@std/testing": "jsr:@std/testing@^1.0.16",
    "hono": "jsr:@hono/hono@^4.9.9",
    "zod": "npm:zod@^4.1.11"
  },
  "unstable": ["cron"],
  "tasks": {
    "check": "deno fmt --check && deno lint",
    "fix": "deno fmt && deno lint",
    "dev": "deno task fix && deno run --allow-net --allow-env --allow-read --watch server.ts",
    "start": "deno run --allow-net --allow-env --allow-read server.ts",
    "token": "deno run --allow-net --allow-env --allow-read token.ts",
    "test": "deno test --allow-net --allow-env --allow-read --allow-sys --unstable-node-globals",
    "test:watch": "deno test --allow-net --allow-env --allow-read --allow-sys --unstable-node-globals --watch",
    "test:coverage": "deno test --allow-net --allow-env --allow-read --allow-sys --unstable-node-globals --coverage=coverage"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "nodeModulesDir": "auto"
}
